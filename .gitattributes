# Ensure shell scripts, Dockerfile and common text files use LF in repo and in checkouts
*.sh     text eol=lf
*.py     text eol=lf
Dockerfile text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.json   text eol=lf
*.env    text eol=lf
* text=auto
/docker/* text eol=lf
/ci/* text eol=lf
/sbt text eol=lf
/docker-*.sh text eol=lf
/sbt-dist/bin/*.bash text eol=lf
/sbt-dist/bin/sbt text eol=lf